---
import Base from './Base.astro';

interface Props {
  title: string;
  summary: string;
  date: Date;
  links: { label: string; url: string }[];
  tags: string[];
  backHref: string;
  backLabel: string;
}

const { title, summary, date, links, tags, backHref, backLabel } = Astro.props;
---

<Base title={title} description={summary}>
  <article class="item-page">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>
    <h1>{title}</h1>
    <p class="item-meta">
      {date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
    </p>
    {
      tags.length > 0 && (
        <div class="tag-row">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )
    }
    <div class="item-body">
      <slot />
    </div>
    {
      links.length > 0 && (
        <section class="item-links">
          <h2>Links</h2>
          <ul>
            {links.map((link) => (
              <li>
                <a href={link.url} target="_blank" rel="noopener noreferrer">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>

<style>
  .back-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .item-page h1 {
    margin-top: 0.75rem;
    font-size: 2rem;
    line-height: 1.2;
  }

  .item-meta {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-top: 0.35rem;
  }

  .item-body {
    margin-top: 1.5rem;
  }

  .item-body :global(h2) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .item-body :global(p) {
    margin-bottom: 1rem;
  }

  .item-body :global(ul),
  .item-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .item-links {
    margin-top: 2rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
  }

  .item-links h2 {
    font-size: 1.15rem;
    margin-bottom: 0.5rem;
  }

  .item-links ul {
    list-style: none;
    padding: 0;
  }

  .item-links a {
    color: var(--accent);
  }
</style>
