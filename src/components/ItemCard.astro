---
import { Image } from 'astro:assets';
import Stars from './Stars.astro';

interface Props {
  href: string;
  title: string;
  summary: string;
  tags: string[];
  rating?: number;
  image?: ImageMetadata;
  imageAlt?: string;
}

const { href, title, summary, tags, rating, image, imageAlt } = Astro.props;
---

<a class="card" href={href}>
  {
    image && (
      <Image class="card-image" src={image} alt={imageAlt ?? title} width={600} />
    )
  }
  <h3>{title}</h3>
  {rating !== undefined && <Stars rating={rating} />}
  <p>{summary}</p>
  {
    tags.length > 0 && (
      <div class="tag-row">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )
  }
</a>
