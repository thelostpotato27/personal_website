---
interface Props {
  href: string;
  title: string;
  summary: string;
  tags: string[];
}

const { href, title, summary, tags } = Astro.props;
---

<a class="card" href={href}>
  <h3>{title}</h3>
  <p>{summary}</p>
  {
    tags.length > 0 && (
      <div class="tag-row">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )
  }
</a>
