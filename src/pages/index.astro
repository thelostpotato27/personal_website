---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ItemCard from '../components/ItemCard.astro';

const byDate = (a: { data: { date: Date } }, b: { data: { date: Date } }) =>
  b.data.date.valueOf() - a.data.date.valueOf();

const technical = (await getCollection('technical')).sort(byDate);
const hobbies = (await getCollection('hobbies')).sort(byDate);
---

<Base title="Jeffrey Chang">
  <section class="hero">
    <h1>Hi, I'm Jeffrey.</h1>
    <p class="section-intro">
      This is where I keep my projects and hobbies. Browse the technical work
      or see what I do for fun.
    </p>
  </section>

  <section>
    <div class="section-head">
      <h2 class="section-title">Technical</h2>
      <a href="/technical/">View all &rarr;</a>
    </div>
    <div class="card-grid">
      {
        technical
          .slice(0, 3)
          .map((item) => (
            <ItemCard
              href={`/technical/${item.id}/`}
              title={item.data.title}
              summary={item.data.summary}
              tags={item.data.tags}
            />
          ))
      }
    </div>
  </section>

  <section>
    <div class="section-head">
      <h2 class="section-title">Hobbies</h2>
      <a href="/hobbies/">View all &rarr;</a>
    </div>
    <div class="card-grid">
      {
        hobbies
          .slice(0, 3)
          .map((item) => (
            <ItemCard
              href={`/hobbies/${item.id}/`}
              title={item.data.title}
              summary={item.data.summary}
              tags={item.data.tags}
            />
          ))
      }
    </div>
  </section>
</Base>

<style>
  .hero {
    margin-bottom: 2.5rem;
  }

  .hero h1 {
    font-size: 2.25rem;
  }

  section + section {
    margin-top: 2.5rem;
  }

  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .section-head a {
    color: var(--accent);
    text-decoration: none;
    font-size: 0.9rem;
  }
</style>
