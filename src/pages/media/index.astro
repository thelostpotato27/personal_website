---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ItemCard from '../../components/ItemCard.astro';
import TagSearch from '../../components/TagSearch.astro';

const items = (await getCollection('media')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Shows, Movies &amp; Animation — Jeffrey Chang">
  <h1 class="section-title">Shows, Movies &amp; Animation</h1>
  <p class="section-intro">Thoughts on what I've been watching.</p>
  <TagSearch />
  <div class="card-grid">
    {
      items.map((item) => (
        <ItemCard
          href={`/media/${item.id}/`}
          title={item.data.title}
          summary={item.data.summary}
          tags={item.data.tags}
          rating={item.data.rating}
          image={item.data.image}
          imageAlt={item.data.imageAlt}
        />
      ))
    }
  </div>
</Base>
