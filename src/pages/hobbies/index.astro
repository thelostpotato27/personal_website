---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ItemCard from '../../components/ItemCard.astro';
import TagSearch from '../../components/TagSearch.astro';

const items = (await getCollection('hobbies')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Hobbies — Jeffrey Chang">
  <h1 class="section-title">Hobbies</h1>
  <p class="section-intro">Things I do for fun outside of work.</p>
  <TagSearch />
  <div class="card-grid">
    {
      items.map((item) => (
        <ItemCard
          href={`/hobbies/${item.id}/`}
          title={item.data.title}
          summary={item.data.summary}
          tags={item.data.tags}
        />
      ))
    }
  </div>
</Base>
